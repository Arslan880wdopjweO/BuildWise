# --- App ---
APP_ENV=development
APP_DEBUG=true
SECRET_KEY=change-me-in-production
API_V1_PREFIX=/api/v1

# --- JWT ---
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Database ---
POSTGRES_USER=pcstore
POSTGRES_PASSWORD=pcstore
POSTGRES_DB=pcstore
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://pcstore:pcstore@db:5432/pcstore

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# --- Celery ---
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
